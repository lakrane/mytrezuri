generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  username     String    @unique
  fullName     String?   @map("full_name")
  bio          String?   @default("")
  referralCode String    @unique @map("referral_code")
  referredBy   String?   @map("referred_by")
  points       Int       @default(0)
  role         String    @default("user")
  avatarUrl    String?   @map("avatar_url")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  vaultItems          VaultItem[]
  tasks               Task[]
  goals               Goal[]
  reminders           Reminder[]
  notifications       Notification[]
  sentCollaborations  Collaboration[] @relation("Initiator")
  receivedCollaborations Collaboration[] @relation("Participant")
  payments            Payment[]
  referralClicks      ReferralClick[]
  comments            Comment[]

  @@map("users")
}

model VaultItem {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        String
  visibility  String   @default("private")
  content     String?
  fileUrl     String?  @map("file_url")
  fileName    String?  @map("file_name")
  fileType    String?  @map("file_type")
  allowDownload Boolean @default(false) @map("allow_download")
  children    Json?
  likes       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  comments        Comment[]
  collaborations  Collaboration[]

  @@map("vault_items")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  itemId    String   @map("item_id")
  item      VaultItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("comments")
}

model Collaboration {
  id            String   @id @default(uuid())
  itemId        String   @map("item_id")
  item          VaultItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  initiatorId   String   @map("initiator_id")
  initiator     User     @relation("Initiator", fields: [initiatorId], references: [id])
  participantId String   @map("participant_id")
  participant   User     @relation("Participant", fields: [participantId], references: [id])
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("collaborations")
}

model ReferralClick {
  id            String   @id @default(uuid())
  referralCode  String   @map("referral_code")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  clickedAt     DateTime @default(now()) @map("clicked_at")
  converted     Boolean  @default(false)
  convertedUserId String? @map("converted_user_id")
  user          User?    @relation(fields: [convertedUserId], references: [id])

  @@map("referral_clicks")
}

model Task {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime? @map("due_date")
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("tasks")
}

model Goal {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  targetValue Float?   @map("target_value")
  currentValue Float?  @default(0) @map("current_value")
  deadline    DateTime?
  category    String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("goals")
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  remindAt    DateTime @map("remind_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("reminders")
}

model Payment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  currency  String   @default("NGN")
  status    String
  reference String   @unique
  plan      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("payments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  link      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
